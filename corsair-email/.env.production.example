# Production / live demo template for Vercel + Neon.
# The app FAILS FAST in production (NODE_ENV=production) if any required value
# below is missing, still set to a dev fallback, or insecure — see src/lib/env.ts.
#
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --- Required ---------------------------------------------------------------

# Encrypts Google tokens in Postgres. MUST stay stable forever once tokens exist,
# or every saved credential becomes undecryptable.
CORSAIR_KEK=replace-with-a-stable-32-byte-hex-secret

# Signs the app session cookie. MUST be different from CORSAIR_KEK (separate
# security domains). Rotating it logs everyone out.
SESSION_SECRET=replace-with-a-different-long-random-secret

# Use the POOLED Neon connection string (host contains "-pooler"); the app
# disables prepared statements automatically for pooled/PgBouncer URLs.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler/DB?sslmode=require

# Must be the real https:// origin (drives cookie `secure` flag + OAuth redirect).
NEXT_PUBLIC_APP_URL=https://your-demo-domain.vercel.app

# --- Google sign-in (identity) ----------------------------------------------
# Separate from the Gmail/Calendar data-access client (which lives in Postgres
# via `corsair setup`). Authorized redirect URI:
#   https://your-demo-domain.vercel.app/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Google data access (Gmail + Calendar) ----------------------------------
# Optional separate OAuth clients for Corsair's Gmail/Calendar consent flow.
# If unset, the app reuses GOOGLE_OAUTH_CLIENT_ID/SECRET. Authorized redirect URI:
#   https://your-demo-domain.vercel.app/api/auth/corsair/callback
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GOOGLECALENDAR_CLIENT_ID=
# GOOGLECALENDAR_CLIENT_SECRET=

# Allow the unverified email/demo login in production (off by default). Leave
# unset for real deployments; enable only for throwaway demos.
# ALLOW_EMAIL_LOGIN=false

# --- Webhooks + cron --------------------------------------------------------
# Shared secret carried in the webhook URL (?token=) and used as the Calendar
# push channel token. When set, /api/webhooks rejects unauthenticated POSTs.
WEBHOOK_SECRET=replace-with-a-random-secret

# Bearer token Vercel Cron sends to /api/cron/renew-watches. Set the SAME value
# in the Vercel project as the `CRON_SECRET` environment variable.
CRON_SECRET=replace-with-a-random-secret

# Full Pub/Sub topic for Gmail watches, e.g. projects/<project>/topics/<topic>.
# Required for Gmail push notifications + automated watch renewal.
GMAIL_TOPIC_ID=

# --- Optional: AI Agent Chat ------------------------------------------------
# Any OpenAI-compatible chat-completions endpoint. Leave blank to disable.
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
# AI_OPERATOR_LABEL=AI
