# Local development values.
# Copy this file to .env.local and replace the placeholder secrets before running OAuth.
#
# PowerShell secret helper:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# CORSAIR_KEK must stay stable once credentials have been stored, or Corsair will no
# longer be able to decrypt saved Google tokens.
CORSAIR_KEK=replace-with-a-stable-32-byte-secret

# SESSION_SECRET signs the app's tenant session cookie. Rotating it will log users out.
SESSION_SECRET=replace-with-a-long-random-secret

# Local Docker Postgres default.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/corsair_email

# Local app URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hosted reference values:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require
# NEXT_PUBLIC_APP_URL=https://your-demo-domain.vercel.app

# Google sign-in (identity) — optional locally. When unset, the unverified email
# login is used (ALLOW_EMAIL_LOGIN defaults to ON in development). Redirect URI:
# http://localhost:3000/api/auth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# ALLOW_EMAIL_LOGIN=true

# Google data access for in-app Gmail/Calendar connection. If these are unset,
# the app reuses GOOGLE_OAUTH_CLIENT_ID/SECRET. Redirect URI:
# http://localhost:3000/api/auth/corsair/callback
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GOOGLECALENDAR_CLIENT_ID=
# GOOGLECALENDAR_CLIENT_SECRET=

# Webhook + cron secrets (optional locally; required for hosted live-sync).
# WEBHOOK_SECRET=
# CRON_SECRET=
# GMAIL_TOPIC_ID=projects/<project>/topics/<topic>

# Provider-neutral AI operator for Agent Chat (optional). Any OpenAI-compatible
# chat-completions endpoint works — OpenAI, xAI/Grok, Gemini (compat), Groq,
# OpenRouter, Mistral, or a local model via Ollama/LM Studio. Leave blank to
# disable the agent; the rest of the app runs normally.
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
# AI_OPERATOR_LABEL=AI
